# Supabase (all four required for uploads + database on production)
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side file uploads (Dashboard → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token from https://supabase.com/dashboard/account/tokens
# (NOT the service_role key — create a token with access to this project)
SUPABASE_MANAGEMENT_TOKEN=

# Cloudflare R2 — Pro/Founder video uploads (bypasses Supabase Free 50 MB cap)
# Setup: Cloudflare Dashboard → R2 → Create bucket → Settings → Public access (r2.dev URL)
#        → Manage R2 API tokens → Create token with Object Read & Write on that bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=seenly-videos
# Public base URL for playback (r2.dev subdomain or custom domain), no trailing slash
# Example: https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Private beta — 4-digit code required for new signups (leave empty to disable gate locally)
SEENLY_BETA_ACCESS_CODE=2435

# Dodo Payments (https://app.dodopayments.com → Developer)
# Use test_mode with Test Mode API keys; use live_mode only with Live API keys.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENV=test_mode
DODO_PRO_PRODUCT_ID=
DODO_FOUNDER_PRODUCT_ID=
