# Supabase (all four required for uploads + database on production)
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side file uploads (Dashboard → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token from https://supabase.com/dashboard/account/tokens
# (NOT the service_role key — create a token with access to this project)
SUPABASE_MANAGEMENT_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dodo Payments (https://app.dodopayments.com → Developer)
# Use test_mode with Test Mode API keys; use live_mode only with Live API keys.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENV=test_mode
DODO_PRO_PRODUCT_ID=
DODO_FOUNDER_PRODUCT_ID=
